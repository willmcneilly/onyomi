{
  "manifest_version": 3,
  "name": "Onyomi",
  "version": "0.1.0",
  "description": "Highlight Japanese text on any webpage and hear a native-sounding reading.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://*.tts.speech.microsoft.com/*"],
  "options_page": "options.html",
  "action": {
    "default_title": "Onyomi"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "speak-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Speak the selected Japanese text"
    }
  }
}
